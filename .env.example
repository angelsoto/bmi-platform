# BMI Platform — Environment Variables

# Database (local SQLite for development)
DATABASE_URL="file:./prisma/dev.db"

# Turso (production database — set both for Vercel/Cloudflare deployment)
# TURSO_DATABASE_URL="libsql://your-db.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"

# Auth — generate with: openssl rand -hex 32
AUTH_SECRET="change-me-to-a-random-string"

# NextAuth URL (set to your deployment URL in production)
AUTH_URL="http://localhost:3000"

# AI Provider (optional — mock provider used when unset)
# ANTHROPIC_API_KEY="sk-ant-..."
